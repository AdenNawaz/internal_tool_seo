generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String   @default("Untitled")
  content         Json?
  status          String   @default("draft")
  targetKeyword   String?
  metaDescription String?
  slug            String?
  checklistScore  Int?
  publishedUrl    String?
  authorEmail     String?
  clusterId       String?
  clusterName     String?
  revampUrl          String?
  isRevamp           Boolean  @default(false)
  secondaryKeywords  Json?
  chatOutline        Json?
  chatResearchState  Json?
  // Create flow fields
  contentType             String?
  intentType              String?
  wordCountTarget         Int?
  country                 String?
  useSmartContext         Boolean  @default(true)
  preferredSources        Json?
  excludedSources         Json?
  allowCompetitorMentions Boolean  @default(true)
  uniqueAngle             String?
  referenceDocIds         Json?
  createdAt          DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ArticleBrief {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId          String   @db.ObjectId
  keyword            String
  competitors        Json
  competitorAvgWords Int
  outline            Json?
  editableOutline    Json?
  paaQuestions       Json?
  gptQueries         Json?
  geoQuestions       Json?
  aeoQuestions       Json?
  revampAnalysis     Json?
  status             String   @default("fetching")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ToneProfile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  type       String
  sourceUrls Json
  profile    String
  examples   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ResearchReport {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword             String
  status              String   @default("pending")
  competitors         Json?
  ownData             Json?
  summary             Json?
  clusters            Json?
  competitorAuthority Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Ranking {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId          String   @db.ObjectId
  keyword            String
  position           Int?
  url                String?
  volume             Int?
  refreshOpportunity Boolean  @default(false)
  checkedAt          DateTime @default(now())
}

model SovSnapshot {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  checkedAt    DateTime @default(now())
  companySOV   Float
  competitors  Json
  keywordCount Int
}

model TrendingAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword     String
  cluster     String
  reportId    String   @db.ObjectId
  volumeNow   Int
  volumePrev  Int
  growthPct   Float
  checkedAt   DateTime @default(now())
  dismissed   Boolean  @default(false)
}

model PinnedItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId String   @db.ObjectId
  type      String
  content   String
  metadata  Json?
  pinnedAt  DateTime @default(now())
}

model ResearchSession {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId     String   @db.ObjectId @unique
  keywords      Json?
  serpHeaders   Json?
  audienceQs    Json?
  aiAnalysis    Json?
  opportunities Json?
  evidence      Json?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CrawlerLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bot       String
  url       String
  visitedAt DateTime @default(now())
}

model VisibilitySnapshot {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  prompt         String
  platform       String
  companyVisible Boolean
  companyCited   Boolean
  competitors    Json
  checkedAt      DateTime @default(now())
}

model TrackedPrompt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  prompt    String
  category  String?
  createdAt DateTime @default(now())
}
