generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String   @default("Untitled")
  content         Json?
  status          String   @default("draft")
  targetKeyword   String?
  metaDescription String?
  slug            String?
  checklistScore  Int?
  publishedUrl    String?
  authorEmail     String?
  clusterId       String?
  clusterName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ArticleBrief {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId          String   @db.ObjectId
  keyword            String
  competitors        Json
  competitorAvgWords Int
  outline            Json?
  editableOutline    Json?
  paaQuestions       Json?
  status             String   @default("fetching")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ToneProfile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  type       String
  sourceUrls Json
  profile    String
  examples   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ResearchReport {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword             String
  status              String   @default("pending")
  competitors         Json?
  ownData             Json?
  summary             Json?
  clusters            Json?
  competitorAuthority Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Ranking {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId          String   @db.ObjectId
  keyword            String
  position           Int?
  url                String?
  volume             Int?
  refreshOpportunity Boolean  @default(false)
  checkedAt          DateTime @default(now())
}

model SovSnapshot {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  checkedAt    DateTime @default(now())
  companySOV   Float
  competitors  Json
  keywordCount Int
}

model TrendingAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword     String
  cluster     String
  reportId    String   @db.ObjectId
  volumeNow   Int
  volumePrev  Int
  growthPct   Float
  checkedAt   DateTime @default(now())
  dismissed   Boolean  @default(false)
}
