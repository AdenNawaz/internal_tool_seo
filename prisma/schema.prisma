generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Article {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String   @default("Untitled")
  content         Json?
  status          String   @default("draft")
  targetKeyword   String?
  metaDescription String?
  slug            String?
  checklistScore  Int?
  publishedUrl    String?
  authorEmail       String?
  authorProfileId   String?  @db.ObjectId
  clusterId       String?
  clusterName     String?
  revampUrl          String?
  isRevamp           Boolean  @default(false)
  secondaryKeywords  Json?
  chatOutline        Json?
  chatResearchState  Json?
  // Create flow fields
  contentType             String?
  intentType              String?
  wordCountTarget         Int?
  country                 String?
  useSmartContext         Boolean  @default(true)
  preferredSources        Json?
  excludedSources         Json?
  allowCompetitorMentions Boolean  @default(true)
  uniqueAngle             String?
  referenceDocIds         Json?
  createdAt          DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ArticleBrief {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId          String   @db.ObjectId
  keyword            String
  competitors        Json
  competitorAvgWords Int
  outline            Json?
  editableOutline    Json?
  paaQuestions       Json?
  gptQueries         Json?
  geoQuestions       Json?
  aeoQuestions       Json?
  revampAnalysis     Json?
  status             String   @default("fetching")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ToneProfile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  type       String
  sourceUrls Json
  profile    String
  examples   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ResearchReport {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword             String
  status              String   @default("pending")
  competitors         Json?
  ownData             Json?
  summary             Json?
  clusters            Json?
  competitorAuthority Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Ranking {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId          String   @db.ObjectId
  keyword            String
  position           Int?
  url                String?
  volume             Int?
  refreshOpportunity Boolean  @default(false)
  checkedAt          DateTime @default(now())
}

model SovSnapshot {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  checkedAt    DateTime @default(now())
  companySOV   Float
  competitors  Json
  keywordCount Int
}

model TrendingAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword     String
  cluster     String
  reportId    String   @db.ObjectId
  volumeNow   Int
  volumePrev  Int
  growthPct   Float
  checkedAt   DateTime @default(now())
  dismissed   Boolean  @default(false)
}

model PinnedItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId String   @db.ObjectId
  type      String
  content   String
  metadata  Json?
  pinnedAt  DateTime @default(now())
}

model ResearchSession {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId     String   @db.ObjectId @unique
  keywords      Json?
  serpHeaders   Json?
  audienceQs    Json?
  aiAnalysis    Json?
  opportunities Json?
  evidence      Json?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CrawlerLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bot       String
  url       String
  visitedAt DateTime @default(now())
}

model VisibilitySnapshot {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  prompt         String
  platform       String
  companyVisible Boolean
  companyCited   Boolean
  competitors    Json
  checkedAt      DateTime @default(now())
}

model TrackedPrompt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  prompt    String
  category  String?
  createdAt DateTime @default(now())
}

model AuthorProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  title       String?
  bio         String?
  credentials String?
  linkedinUrl String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
}

model Integration {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  type         String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
}

model JobLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  queue       String
  jobName     String
  jobId       String
  status      String    // queued | active | completed | failed
  data        Json?
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?      // ms
  createdAt   DateTime  @default(now())
}

model RankingAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId   String   @db.ObjectId
  type        String   // drop | opportunity | recovery
  keyword     String?
  oldPosition Int?
  newPosition Int?
  diagnosis   String?
  primaryFix  String?
  urgency     String   @default("medium") // high | medium | low
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CompetitorSnapshot {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  domain      String
  url         String
  contentHash String
  wordCount   Int?
  headings    Json?
  scrapedAt   DateTime @default(now())
}

model CompetitorAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // content_change | new_content | keyword_entry
  domain      String
  url         String
  clusterName String?
  summary     String?
  threat      String   @default("medium") // high | medium | low
  dismissed   Boolean  @default(false)
  detectedAt  DateTime @default(now())
}

model VisibilityAlert {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  promptId   String   @db.ObjectId
  type       String   // gained_visibility | lost_visibility | gained_citation | lost_citation
  platform   String
  details    String
  dismissed  Boolean  @default(false)
  detectedAt DateTime @default(now())
}

model VisibilityAnalysis {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  topPerformingTopics  Json
  consistentCompetitors Json
  citationPatterns     Json
  recommendedActions   Json
  analysedAt           DateTime @default(now())
}

model SuggestedPrompt {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  prompt     String
  category   String
  rationale  String
  applied    Boolean  @default(false)
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ContentQualityScore {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId String   @db.ObjectId
  eeat      Int
  geo       Int
  seo       Int
  overall   Int
  breakdown Json
  scoredAt  DateTime @default(now())
}

model QualityDecayAlert {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId            String   @db.ObjectId
  oldScore             Int
  newScore             Int
  decayReason          String?
  competitorAdvantages Json?
  topFix               String?
  estimatedScoreGain   Int?
  dismissed            Boolean  @default(false)
  detectedAt           DateTime @default(now())
}

model ImprovementBrief {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId           String   @db.ObjectId
  obsoleteContent     Json
  newSectionsToAdd    Json
  statsToUpdate       Json
  wordCountTarget     Int?
  estimatedRefreshTime String?
  priorityActions     Json
  applied             Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model ClusterHealthScore {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  reportId        String   @db.ObjectId
  clusterName     String
  coverageScore   Int
  rankingScore    Int
  velocityScore   Int
  competitorScore Int
  aiScore         Int
  overall         Int
  scoredAt        DateTime @default(now())
}

model ClusterHealthAlert {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  reportId       String   @db.ObjectId
  clusterName    String
  dropReason     String?
  recommendation String?
  dismissed      Boolean  @default(false)
  detectedAt     DateTime @default(now())
}

model NextArticleRecommendation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  reportId         String?  @db.ObjectId
  action           String   // new_article | refresh | gap_fill | trend_capture
  target           String
  reasoning        String
  expectedImpact   String?
  urgency          String   @default("this_week")
  estimatedEffort  String?
  dismissed        Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model RefreshBrief {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  articleId           String   @db.ObjectId @unique
  refreshScore        Int
  obsoleteContent     Json?
  newSectionsToAdd    Json?
  statsToUpdate       Json?
  wordCountTarget     Int?
  estimatedRefreshTime String?
  priorityActions     Json?
  applied             Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model LinkOpportunity {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  sourceArticleId String   @db.ObjectId
  targetArticleId String   @db.ObjectId
  suggestedAnchor String
  context         String
  confidence      String   @default("medium") // high | medium
  applied         Boolean  @default(false)
  dismissed       Boolean  @default(false)
  detectedAt      DateTime @default(now())
}

model LinkMapSnapshot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nodes     Json
  edges     Json
  orphaned  Json
  createdAt DateTime @default(now())
}
